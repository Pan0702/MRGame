# =============================================================================
# Unreal Engine 5.7 .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Unreal Engine ビルド生成物
# -----------------------------------------------------------------------------
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# -----------------------------------------------------------------------------
# Unreal Engine プラグイン（自作以外）
# -----------------------------------------------------------------------------
Plugins/*/Binaries/
Plugins/*/Intermediate/

# MetaXR Plugins
Plugins/MetaXR/
Plugins/MetaXRHaptics/

# -----------------------------------------------------------------------------
# Visual Studio / Rider
# -----------------------------------------------------------------------------
.vs/
.idea/
*.VC.db
*.VC.opendb
*.suo
*.user
*.sln
*.xcworkspace
*.xcodeproj

# -----------------------------------------------------------------------------
# コンパイル済みバイナリ
# -----------------------------------------------------------------------------
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.exe

# -----------------------------------------------------------------------------
# パッケージ／ステージング
# -----------------------------------------------------------------------------
Releases/
Staged/
StarterContent/

# -----------------------------------------------------------------------------
# Android SDK / NDK / JDK（誤ってコミットされたものを除外）
# -----------------------------------------------------------------------------

# Android SDK
Android/
android-sdk/
AndroidSDK/
sdk/
platforms/
platform-tools/
tools/
build-tools/
emulator/
extras/
system-images/
licenses/

# Android NDK
ndk/
ndk-bundle/
AndroidNDK/
android-ndk*/

# JDK / JRE
jdk/
jre/
JDK/
JRE/
java/
Java/

# よくある SDK/NDK/JDK の配置パス
Engine/Extras/Android/
LocalSDK/
SDKs/

# プロジェクト内 Sdk フォルダ（JDK/Android SDK/NDK まとめて）
Sdk/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~

# -----------------------------------------------------------------------------
# ログ・クラッシュダンプ
# -----------------------------------------------------------------------------
*.log
*.dmp
CrashReportClient/

# -----------------------------------------------------------------------------
# Xcode（iOS / macOS ビルド）
# -----------------------------------------------------------------------------
*.pbxproj

# -----------------------------------------------------------------------------
# 自動生成ファイル
# -----------------------------------------------------------------------------
*.generated.h
*.generated.cpp
